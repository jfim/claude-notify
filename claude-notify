#!/usr/bin/env bash
set -euo pipefail

CONFIG_FILE="$HOME/.claude-notify"

# Defaults
server="https://ntfy.sh"
topic=""
token=""

# Trim leading/trailing whitespace (pure bash, no xargs)
trim() {
    local s="$1"
    s="${s#"${s%%[![:space:]]*}"}"
    s="${s%"${s##*[![:space:]]}"}"
    printf '%s' "$s"
}

# Read config
if [[ -f "$CONFIG_FILE" ]]; then
    # Warn if config file is readable by others
    if stat -c '%a' "$CONFIG_FILE" &>/dev/null; then
        perms=$(stat -c '%a' "$CONFIG_FILE")
    else
        perms=$(stat -f '%Lp' "$CONFIG_FILE")
    fi
    if [[ "$perms" =~ [0-7][^0][0-7]|[0-7][0-7][^0] ]]; then
        echo "Warning: $CONFIG_FILE is readable by others. Run: chmod 600 $CONFIG_FILE" >&2
    fi

    while IFS='=' read -r key value; do
        key=$(trim "$key")
        value=$(trim "$value")
        [[ -z "$key" || "$key" == \#* ]] && continue
        case "$key" in
            server) server="$value" ;;
            topic)  topic="$value" ;;
            token)  token="$value" ;;
        esac
    done < "$CONFIG_FILE"
else
    echo "Error: Config file not found at $CONFIG_FILE" >&2
    echo "Create it with at least: topic=<your-topic>" >&2
    exit 1
fi

if [[ -z "$topic" ]]; then
    echo "Error: 'topic' not set in $CONFIG_FILE" >&2
    exit 1
fi

# Parse arguments
title=""
while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)
            echo "Usage: claude-notify [-t title] <message>"
            echo "Send push notifications via ntfy.sh."
            echo ""
            echo "Options:"
            echo "  -t, --title    Set the notification title"
            echo "  -h, --help     Show this help message"
            echo ""
            echo "Config: ~/.claude-notify (server, topic, token)"
            exit 0
            ;;
        -t|--title)
            title="${2:?Error: -t requires a value}"
            title="${title//$'\r'/}"
            title="${title//$'\n'/ }"
            shift 2
            ;;
        --)
            shift
            break
            ;;
        *)
            break
            ;;
    esac
done

# Message from args or stdin
if [[ $# -gt 0 ]]; then
    message="$*"
elif [[ ! -t 0 ]]; then
    message=$(cat)
else
    echo "Usage: claude-notify [-t title] <message>" >&2
    exit 1
fi

# Build curl args
curl_args=(-s -o /dev/null -w "%{http_code}")

if [[ -n "$title" ]]; then
    curl_args+=(-H "Title: $title")
fi

curl_args+=(-d "$message" "$server/$topic")

# Send notification, passing auth header via stdin to avoid token in process list
if [[ -n "$token" ]]; then
    http_code=$(curl -H @- "${curl_args[@]}" <<< "Authorization: Bearer $token")
else
    http_code=$(curl "${curl_args[@]}")
fi

if [[ "$http_code" -ge 200 && "$http_code" -lt 300 ]]; then
    echo "Notification sent."
else
    echo "Error: server returned HTTP $http_code" >&2
    exit 1
fi
